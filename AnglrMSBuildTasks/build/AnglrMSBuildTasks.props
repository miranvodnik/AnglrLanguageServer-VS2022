<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<PropertyGroup>
    <AnglrTaskAssemblyPath>$(MSBuildThisFileDirectory)..\lib\netstandard2.0\AnglrMSBuildTasks.dll</AnglrTaskAssemblyPath>
    <AnglrDefaultDebug>false</AnglrDefaultDebug>
    <AnglrDefaultTree>true</AnglrDefaultTree>
    <AnglrDefaultLoop>true</AnglrDefaultLoop>
    <AnglrDefaultIterator>false</AnglrDefaultIterator>
    <AnglrDefaultPrecedence>false</AnglrDefaultPrecedence>
    <AnglrDefaultOutputDir>Syntax\</AnglrDefaultOutputDir>
    <AnglrDefaultCode>cs</AnglrDefaultCode>
	</PropertyGroup>

  <ItemDefinitionGroup>
    <AnglrFile>
      <Debug>$(AnglrDefaultDebug)</Debug>
      <Tree>$(AnglrDefaultTree)</Tree>
      <Loop>$(AnglrDefaultLoop)</Loop>
      <Iterator>$(AnglrDefaultIterator)</Iterator>
      <Precedence>$(AnglrDefaultPrecedence)</Precedence>
      <OutputDir>$(AnglrDefaultOutputDir)</OutputDir>
      <Code>$(AnglrDefaultCode)</Code>
    </AnglrFile>
  </ItemDefinitionGroup>

  <ItemGroup>
    <AvailableItemName Include="Anglr" />
  </ItemGroup>

</Project>
