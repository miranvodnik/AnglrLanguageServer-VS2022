<?xml version="1.0" encoding="utf-8" ?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <UsingTask TaskName="AnglrMSBuildTasks.Anglr"
             AssemblyFile="$(AnglrTaskAssemblyPath)" />

  <Target Name="RunAnglr"
          BeforeTargets="BeforeCompile"
          Inputs="@(AnglrFile)"
          Outputs="@(AnglrFile->'$(IntermediateOutputPath)%(Filename).g.cs')"
          Condition="'@(AnglrFile)' != ''">

    <Message Text="Running Anglr on @(AnglrFile)" Importance="Low" />

    <Anglr 
      SourceFile="@(AnglrFile)"
      Debug="%(AnglrFile.Debug)"
      Tree="%(AnglrFile.Tree)"
      Loop="%(AnglrFile.Loop)"
      Iterator="%(AnglrFile.Iterator)"
      Precedence="%(AnglrFile.Precedence)"
      OutputDir="%(AnglrFile.OutputDir)"
      Code="%(AnglrFile.Code)">
      <Output TaskParameter="OutputSourceFileList" ItemName="GeneratedSources" />
    </Anglr>

    <!-- Add generated files to compilation -->
    <ItemGroup>
      <Compile Include="@(GeneratedSources)" />
    </ItemGroup>

  </Target>

</Project>
