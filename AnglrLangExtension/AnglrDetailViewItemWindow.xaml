<UserControl x:Class="AnglrLangExtension.AnglrDetailViewItemWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnglrLangExtension"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Expander Grid.Row="0" Grid.Column="0" Header="{Binding FileName}">
            <DataGrid
                x:Name="anglrGetParserSyntaxRuleDatas"
                VerticalAlignment="Center"
                ItemsSource="{Binding AnglrGetParserSyntaxRuleDatas}"
                AutoGenerateColumns="False"
                SelectionChanged="anglrGetParserSyntaxRuleDatas_SelectionChanged"
                >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Syntax Rule Nr." Binding="{Binding SyntaxRuleName.Id}" />
                    <DataGridTextColumn Header="Syntax Rule Name" Binding="{Binding SyntaxRuleName.Name}" />
                </DataGrid.Columns>

            </DataGrid>
        </Expander>
    </Grid>
</UserControl>
