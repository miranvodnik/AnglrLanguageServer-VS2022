<UserControl x:Class="AnglrLangExtension.AnglrDebugWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AnglrLangExtension"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="50*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Label x:Name="startProgramPathName" Grid.Row="0" Grid.Column="0" Content="Start Program:" Margin="5, 5, 5, 5"/>
        <TextBox x:Name="startProgramPathValue" Grid.Row="0" Grid.Column="1" MinWidth="400" AcceptsReturn="True" TextWrapping="Wrap" Margin="5, 5, 5, 5"/>
        <Button x:Name="startProgramPathBrowser" Grid.Row="0" Grid.Column="2" Content="Select Start Program..." Margin="5, 5, 5, 5" Click="startProgramPathBrowser_Click"/>
        <Label x:Name="commandLineParametersName" Grid.Row="1" Grid.Column="0" Content="Command line parameters:" Margin="5, 5, 5, 5"/>
        <TextBox x:Name="commandLineParametersValue" Grid.Row="1" Grid.Column="1" MinWidth="400" AcceptsReturn="True" TextWrapping="Wrap" Margin="5, 5, 5, 5"/>
        <Label x:Name="workingDirectoryPathName" Grid.Row="2" Grid.Column="0" Content="Working Directory:" Margin="5, 5, 5, 5"/>
        <TextBox x:Name="workingDirectoryPathValue" Grid.Row="2" Grid.Column="1" MinWidth="400" AcceptsReturn="True" TextWrapping="Wrap" Margin="5, 5, 5, 5"/>
        <Button x:Name="workingDirectoryPathBrowser" Grid.Row="2" Grid.Column="2" Content="Select Working Directory..." Margin="5, 5, 5, 5" Click="workingDirectoryPathBrowser_Click"/>
        <WrapPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="5, 10, 5, 0">
            <Button x:Name="clearButton" Content="Clear Entry" Margin="5, 5, 5, 5" Click="clearButton_Click"/>
            <Button x:Name="addDebugEntry" Content="Save Entry" Margin="0, 5, 0, 5" Click="addDebugEntry_Click" />
        </WrapPanel>
        <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" BorderThickness="1" BorderBrush="LightBlue">
            <StackPanel Orientation="Vertical">
                <Label Content="Debug Entries:" Margin="10, 5, 30, 5" FontStretch="Expanded"/>
                <DataGrid
                    x:Name="anglrDebugWindowGrid"
                    ItemsSource="{Binding AnglrDebuggers}"
                    AutoGenerateColumns="False"
                    SelectionChanged="anglrDebugWindowGrid_SelectionChanged"
                    >
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Program" Binding="{Binding FileName}" />
                        <DataGridTextColumn Header="Command Line" Binding="{Binding Arguments}" />
                        <DataGridTextColumn Header="Working Directory" Binding="{Binding WorkingDirectory}" />
                    </DataGrid.Columns>
                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Grid Margin="0, 10, 0, 10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Program:" HorizontalAlignment="Right" Margin="0, 0, 10, 0"/>
                                <Label Grid.Row="1" Grid.Column="0" Content="Arguments:" HorizontalAlignment="Right" Margin="0, 0, 10, 0"/>
                                <Label Grid.Row="2" Grid.Column="0" Content="Working Directory:" HorizontalAlignment="Right" Margin="0, 0, 10, 0"/>
                                <Label Grid.Row="3" Grid.Column="0" Content="Actions:" HorizontalAlignment="Right" Margin="0, 0, 10, 0"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FileName}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Arguments}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WorkingDirectory}"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" >
                                    <Button x:Name="startButton" Content="Start" Margin="10, 0, 0, 0" FontStretch="Expanded" Click="startButton_Click"/>
                                    <Button x:Name="editButton" Content="Edit" Margin="10, 0, 0, 0" FontStretch="Expanded" Click="editButton_Click"/>
                                    <Button x:Name="deleteButton" Content="Delete" Margin="10, 0, 0, 0" FontStretch="Expanded" Click="deleteButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
