        <span class="regex-name" id="assignment-sign">assignment-sign</span> <span class="regex-def">{colon}{colon}{equals-sign}</span>
        <span class="regex-name" id="range-separator">range-separator</span> <span class="regex-def">{full-stop}{full-stop}</span>
        <span class="regex-name" id="ellipses">ellipses</span> <span class="regex-def">{full-stop}{full-stop}{full-stop}</span>
        <span class="regex-name" id="left-version-brackets">left-version-brackets</span> <span class="regex-def">{left-square-bracket}{left-square-bracket}</span>
