        <span class="regex-name" id="new-line">new-line</span> <span class="regex-def">[\r\f\n]</span>
        <span class="regex-name" id="bin-digit">bin-digit</span> <span class="regex-def">[0-1]</span>
        <span class="regex-name" id="oct-digit">oct-digit</span> <span class="regex-def">[0-7]</span>
        <span class="regex-name" id="decimal-digit">decimal-digit</span> <span class="regex-def">[0-9]</span>
        <span class="regex-name" id="positive-decimal-digit">positive-decimal-digit</span> <span class="regex-def">[1-9]</span>
