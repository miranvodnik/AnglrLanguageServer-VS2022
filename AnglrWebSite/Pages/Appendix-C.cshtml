        <span class="regex-name" id="letter">letter</span> <span class="regex-def">[a-zA-Z]</span>
        <span class="regex-name" id="upper-case-letter">upper-case-letter</span> <span class="regex-def">[A-Z]</span>
        <span class="regex-name" id="lower-case-letter">lower-case-letter</span> <span class="regex-def">[a-z]</span>
        <span class="regex-name" id="hyphen-character">hyphen-character</span> <span class="regex-def">[_-]</span>
        <span class="regex-name" id="exclamation-mark">exclamation-mark</span> <span class="regex-def">\!</span>
        <span class="regex-name" id="quotation-mark">quotation-mark</span> <span class="regex-def">\&quot;</span>
        <span class="regex-name" id="ampersand">ampersand</span> <span class="regex-def">\&amp;</span>
