@page
@model IndexModel
@{
    ViewData["Title"] = "Anglr Home Page";
    ViewData ["Content"] = "Anglr Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>WEB PAGE IS UNDER CONSTRUCTION</p>
    <div id="demo" class="carousel slide" data-bs-ride="carousel">

        <!-- Indicators/dots -->
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#demo" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="1"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="2"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="3"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="4"></button>
            <button type="button" data-bs-target="#demo" data-bs-slide-to="5"></button>
        </div>

        <!-- The slideshow/carousel -->
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="~/images/Anglr Compiler.png" alt="Anglr Compiler" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Anglr Compiler</h3>
                    <p>Command line tool which converts the file containing syntax specs into the set of C# files</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/Anglr File Editor.png" alt="Anglr File Editor" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Anglr File Editor</h3>
                    <p>Editor within Microsoft VisualStudio used to change contents of ANGLR files</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/Anglr Explorer View.png" alt="Anglr Explorer View" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Anglr Explorer View</h3>
                    <p>Structured view of ANGLR files</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/Anglr State View.png" alt="Anglr State View" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Anglr State View</h3>
                    <p>Visual representation of stack automata for shift/reduce parser associated with given ANGLR file</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/Anglr Debug View.png" alt="Anglr Debug View" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Anglr Debug View</h3>
                    <p>Set of specifications which should be used to debug shift/reduce parsers</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="~/images/Anglr Debug Panel.png" alt="Anglr Debug Panel" class="d-block" style="width:100%">
                <div class="carousel-caption">
                    <h3>Anglr Debug Panel</h3>
                    <p>View representing current snapshot of shift/reduce parser state</p>
                </div>
            </div>
        </div>

        <!-- Left and right controls/icons -->
        <button class="carousel-control-prev" type="button" data-bs-target="#demo" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#demo" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</div>
