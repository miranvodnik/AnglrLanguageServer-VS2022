<span class="attribute-brace">[</span>
        <span class="attribute-name" id="Description">Description</span> <span class="attribute-val-name" id="Hover">Hover</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;true&#39;</span>
        <span class="attribute-val-name" id="Text">Text</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;anglr syntax rule specification comes in two flavours. First one is&#39;</span>
