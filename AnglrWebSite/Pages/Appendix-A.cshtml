        <span class="attribute-val-name" id="Text">Text</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;  rule for anglr syntax rule specifies also syntax rule for grouping)&#39;</span>
        <span class="attribute-val-name" id="Text">Text</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;  enclosed with curly braces.&#39;</span>
        <span class="attribute-val-name" id="Text">Text</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;The depth of nesting is thus theoretically unlimited.&#39;</span>
<span class="attribute-brace">]</span>
