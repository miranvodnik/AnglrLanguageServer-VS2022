        <span class="def-separator">|</span>    <a href="#-attribute-list-"><span class="rule-ref">&lt;attribute list&gt;</span></a> <span class="reserved-word">?</span> <a href="#-identifier-"><span class="identifier-name">&lt;identifier&gt;</span></a> <span class="string-name">&#39;{&#39;</span> <a href="#-anglr-syntax-rule-list-"><span class="rule-ref">&lt;anglr syntax rule list&gt;</span></a> <span class="reserved-word">?</span> <span class="string-name">&#39;}&#39;</span>
        <span class="def-separator">;</span>

<span class="attribute-brace">[</span>
        <span class="attribute-name" id="Description">Description</span> <span class="attribute-val-name" id="Hover">Hover</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;true&#39;</span>
        <span class="attribute-val-name" id="Text">Text</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;Nested anglr syntax production list is used to separate elements in name lists&#39;</span>
        <span class="attribute-val-name" id="Text">Text</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;and to specify more compact forms of syntax rules. Optional name specified&#39;</span>
        <span class="attribute-val-name" id="Text">Text</span><span class="def-separator">=</span><span class="attribute-val-value">&#39;within it, or generated one if this name is not specified, is used to generate&#39;</span>
