            <section id="parser part">
                <div class="col-md-12">
                    <h2>Odstavek s sintaksnimi definicijami</h2>
                    <div class="panel border bg-light flex-column">
                        <pre>
&#60parser part&#62
    :	&#60attribute list&#62 ? '%parser' &#60identifier&#62 '%{' &#60anglr syntax rule list&#62 ? '%}'
    ;
                        </pre>
                    </div>
                </div>
            </section>
            <section id="attribute list">
                <div class="col-md-12">
                    <h2>Spisek atributov</h2>
                    <div class="panel border bg-light flex-column">
                        <pre>
&#60attribute list&#62
    :	&#60attribute&#62 +
    ;
                        </pre>
                    </div>
                </div>
            </section>
            <section id="attribute">
                <div class="col-md-12">
                    <h2>Atribut</h2>
                    <div class="panel border bg-light flex-column">
                        <pre>
&#60attribute&#62
    :	'[' &#60identifier&#62 &#60name value list&#62 ? ']'
    ;
