&#60anglr syntax rule&#62
    :	&#60attribute list&#62 ? &#60identifier&#62 ':' &#60anglr syntax production list&#62 ';'
    |	&#60attribute list&#62 ? &#60identifier&#62 '{' &#60anglr syntax rule list&#62 ? '}'
    ;
